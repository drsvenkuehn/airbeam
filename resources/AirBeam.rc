// IDI_TRAY_CONN_001 through IDI_TRAY_CONN_008  ICON  "icons/tray_connecting_00N.ico"

// ── String table — English (canonical; other locales in locales/strings_*.rc) ─
// Included via strings_en.rc at build time
#include "locales/strings_en.rc"
