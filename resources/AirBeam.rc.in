// AirBeam.rc — Win32 resource script
// Generated stubs; full STRINGTABLE in locales/strings_en.rc

#include <winres.h>

// ── Version information ──────────────────────────────────────────────────────
VS_VERSION_INFO VERSIONINFO
  FILEVERSION     @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
  PRODUCTVERSION  @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
  FILEFLAGSMASK   VS_FFI_FILEFLAGSMASK
  FILEFLAGS       0
  FILEOS          VOS_NT_WINDOWS32
  FILETYPE        VFT_APP
  FILESUBTYPE     VFT2_UNKNOWN
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904B0"   // English (US), Unicode
    BEGIN
      VALUE "CompanyName",      "AirBeam Contributors"
      VALUE "FileDescription",  "AirBeam - Windows AirPlay Audio Sender"
      VALUE "FileVersion",      "@PROJECT_VERSION_MAJOR@.@PROJECT_VERSION_MINOR@.@PROJECT_VERSION_PATCH@.0"
      VALUE "InternalName",     "AirBeam"
      VALUE "LegalCopyright",   "MIT License"
      VALUE "OriginalFilename", "AirBeam.exe"
      VALUE "ProductName",      "AirBeam"
      VALUE "ProductVersion",   "@PROJECT_VERSION_MAJOR@.@PROJECT_VERSION_MINOR@.@PROJECT_VERSION_PATCH@.0"
    END
  END
  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x0409, 1200
  END
END

// ── Application icon (4 states + 8 animation frames) ─────────────────────────
#include "resource_ids.h"

IDI_TRAY_IDLE       ICON  "icons/airbeam_idle.ico"
IDI_TRAY_STREAMING  ICON  "icons/airbeam_streaming.ico"
IDI_TRAY_ERROR      ICON  "icons/airbeam_error.ico"
IDI_TRAY_CONN_001   ICON  "icons/airbeam_connecting_001.ico"
IDI_TRAY_CONN_002   ICON  "icons/airbeam_connecting_002.ico"
IDI_TRAY_CONN_003   ICON  "icons/airbeam_connecting_003.ico"
IDI_TRAY_CONN_004   ICON  "icons/airbeam_connecting_004.ico"
IDI_TRAY_CONN_005   ICON  "icons/airbeam_connecting_005.ico"
IDI_TRAY_CONN_006   ICON  "icons/airbeam_connecting_006.ico"
IDI_TRAY_CONN_007   ICON  "icons/airbeam_connecting_007.ico"
IDI_TRAY_CONN_008   ICON  "icons/airbeam_connecting_008.ico"

// ── String table — English (canonical; other locales in locales/strings_*.rc) ─
// Included via strings_en.rc at build time
#include "locales/strings_en.rc"
